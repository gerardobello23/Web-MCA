---
import SiteLayout from "../layouts/SiteLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";

const modalities = [
  {
    title: "Cheerleading recreativo",
    description:
      "Sesiones centradas en fundamentos, acondicionamiento y coreografías básicas, en ambiente relajado y motivador. Perfecto para iniciarse en el deporte.",
    idealFor: "Principiantes absolutos · personas que buscan actividad física en equipo",
    comingSoon: false,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m8 22 4-10 4 10"/><circle cx="12" cy="6" r="2"/></svg>`,
  },
  {
    title: "Cheerleading competitivo",
    description:
      "Entrenamiento intensivo para equipos que compiten a nivel nacional. Técnicas avanzadas: stunts, tumbling, jumps, dance. Preparación física específica y trabajo coreográfico complejo.",
    idealFor: "Atletas con experiencia que buscan competir",
    comingSoon: false,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>`,
  },
  {
    title: "Tumbling",
    description:
      "Clases especializadas en acrobacia de suelo, desde volteretas básicas hasta pases avanzados. Grupos reducidos para atención personalizada.",
    idealFor: "Atletas que quieren mejorar sus habilidades acrobáticas",
    comingSoon: false,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>`,
  },
  {
    title: "Stunts y técnica",
    description:
      "Sesiones enfocadas en pirámides, elevaciones y trabajo de bases y flyers. La seguridad como prioridad absoluta. Progresión técnica guiada.",
    idealFor: "Todos los niveles que quieren perfeccionar esta disciplina",
    comingSoon: false,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`,
  },
];

const sessionIncludes = [
  "Calentamiento y preparación física",
  "Técnica específica de cheerleading",
  "Trabajo en equipo y construcción de rutinas",
  "Estiramientos y prevención de lesiones",
  "Feedback individualizado de entrenadores certificados",
];
---

<SiteLayout
  title="Clases de Cheerleading en Madrid · MCA"
  description="Clases de cheerleading en Madrid todos los niveles. Viernes 19-22h y domingos 10-12h en Ciudad Lineal."
>
  <!-- HERO -->
  <section class="relative bg-mca-navy-dark text-mca-white overflow-hidden">
    <img
      src="/brand/logo-circular-blanco.png"
      alt=""
      aria-hidden="true"
      class="absolute -right-24 -bottom-24 w-[28rem] h-[28rem] opacity-5 pointer-events-none"
    />
    <div class="relative max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-16 md:py-24">
      <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-4">
        Entrenamientos
      </p>
      <h1 class="text-5xl md:text-7xl leading-none font-display font-bold mb-6 max-w-3xl">
        Diseñados para ti
      </h1>
      <p class="text-lg md:text-xl text-mca-white/70 max-w-2xl">
        Clases de cheer en Madrid que combinan técnica, acondicionamiento físico y diversión. Programas adaptados a diferentes niveles y objetivos deportivos.
      </p>
    </div>
  </section>

  <!-- MODALIDADES -->
  <section class="py-16 md:py-24 bg-mca-white">
    <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
      <div class="max-w-3xl mb-12">
        <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-2">
          Modalidades
        </p>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-mca-navy">
          Cuatro caminos hacia el cheerleading
        </h2>
      </div>

<div class="grid md:grid-cols-2 gap-6">
        {
          modalities.map((m) => (
            <Card>
              <div class="flex items-start justify-between mb-4 gap-4">
                <div class="text-mca-red" set:html={m.icon} />
                {m.comingSoon && (
                  <span class="text-xs uppercase tracking-widest font-medium px-3 py-1 rounded-sm bg-mca-warning/15 text-mca-slate-900 whitespace-nowrap">
                    Disponible a partir de septiembre 2026
                  </span>
                )}
              </div>
              <h3 class="text-2xl mb-3">{m.title}</h3>
              <p class="text-mca-slate-700 mb-4 leading-relaxed">{m.description}</p>
              <p class="text-sm text-mca-slate-500">
                <span class="font-medium uppercase tracking-widest text-xs text-mca-navy">Ideal para</span>
                <br />
                {m.idealFor}
              </p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <!-- QUÉ INCLUYEN LAS SESIONES -->
  <section class="py-16 md:py-24 bg-mca-slate-50">
    <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-start">
      <div>
        <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-2">
          ¿Qué incluyen?
        </p>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-mca-navy mb-4">
          Cada sesión, completa
        </h2>
        <p class="text-mca-slate-700 text-lg">
          Da igual la modalidad: todas nuestras sesiones siguen una estructura
          que cubre la preparación, la técnica y la recuperación.
        </p>
      </div>

      <ul class="space-y-6">
        {
          sessionIncludes.map((item) => (
            <li class="flex items-start gap-4">
              <span class="shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-mca-red/10 text-mca-red mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              <span class="text-mca-navy font-medium text-lg leading-snug">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- INSTALACIONES -->
  <section class="relative bg-mca-navy text-mca-white overflow-hidden">
    <img
      src="/brand/logo-circular-blanco.png"
      alt=""
      aria-hidden="true"
      class="absolute -left-24 -top-24 w-[28rem] h-[28rem] opacity-5 pointer-events-none"
    />
    <div class="relative max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-16 md:py-24 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-4">
          Instalaciones
        </p>
        <h2 class="text-4xl md:text-5xl font-display font-bold mb-6">
          Equipamiento profesional
        </h2>
        <p class="text-mca-white/80 text-lg leading-relaxed mb-4">
          Entrenamos en instalaciones deportivas equipadas en Ciudad Lineal,
          con todo el material necesario para un entrenamiento seguro y
          profesional: colchonetas, airtrack para tumbling, equipamiento de
          stunts y más.
        </p>
        <p class="text-mca-white/60 text-sm italic mb-6">
  Calle de Vital Aza, 56 · Ciudad Lineal · 28017 Madrid
</p>

<a href="https://maps.google.com/?q=Calle+de+Vital+Aza,+56,+Ciudad+Lineal,+Madrid"
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center gap-2 bg-mca-red text-mca-white text-sm font-medium uppercase tracking-wide px-5 py-3 rounded-sm hover:bg-mca-red/90 transition-colors"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
    <circle cx="12" cy="10" r="3"/>
  </svg>
  ¿Cómo llegar?
</a>
      </div>

      <div id="instalaciones-carousel" class="relative aspect-video rounded-sm overflow-hidden min-h-72">
{[
          "/images/IMG_6468.webp",
          "/images/IMG_6471.webp",
          "/images/IMG_6473.webp",
          "/images/IMG_6459.webp",
          "/images/IMG_6464.webp",
          "/images/IMG_6458.webp",
        ].map((src, i) => (
          <img
            src={src}
            alt=""
            aria-hidden="true"
            class="absolute inset-0 w-full h-full object-cover"
            data-slide-inst={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-16 md:py-24 bg-mca-white">
    <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-mca-navy mb-4">
        ¿Quieres probar una sesión?
      </h2>
      <p class="text-mca-slate-700 text-lg max-w-xl mx-auto mb-8">
        Tu primera clase es gratis. Sin compromiso. Te recomendaremos la
        modalidad que mejor encaje con tu nivel.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <Button variant="primary" href="#" data-prueba-modal>
          Reserva tu prueba gratuita
        </Button>
        <Button variant="ghost" href="/equipos">
          Ver equipos
        </Button>
      </div>
    </div>
  </section>
<script>
  const slides = Array.from(document.querySelectorAll("[data-slide-inst]")) as HTMLElement[];
  const total = slides.length;
  let current = 0;

  slides.forEach((slide, i) => {
    slide.style.transition = "none";
    slide.style.transform = `translateX(${i * 100}%)`;
  });

  setInterval(() => {
    current = (current + 1) % total;
    slides.forEach((slide, i) => {
      slide.style.transition = "transform 0.8s ease-in-out";
      slide.style.transform = `translateX(${(i - current) * 100}%)`;
    });
  }, 4000);
</script>
</SiteLayout>
