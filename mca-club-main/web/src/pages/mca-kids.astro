---
import SiteLayout from "../layouts/SiteLayout.astro"
---

<SiteLayout
  title="MCA Kids · Madrid Cheer Athletics"
  description="Programa de cheerleading para niños en Madrid. MCA Kids, próximamente."
>

<section class="min-h-[80vh] bg-mca-navy-dark text-mca-white flex items-center justify-center font-kids">
    <div class="text-center px-4">
      <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-4">MCA Kids</p>
      <h1 class="text-5xl md:text-7xl font-display font-bold mb-6">
        Próximamente
      </h1>
      <p class="text-lg text-mca-white/70 max-w-md mx-auto">
        Estamos preparando algo especial para los más pequeños. Disponible a partir de septiembre 2026.
      </p>
    </div>
  </section>

</SiteLayout>
