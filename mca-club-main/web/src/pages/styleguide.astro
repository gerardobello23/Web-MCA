---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import Input from "../components/Input.astro";

const colorTokens = [
  { name: "mca-red", hex: "#E31837", origin: "Oficial", role: "CTAs grandes, decoración" },
  { name: "mca-red-dark", hex: "#B0122A", origin: "Sugerido", role: "Hover · texto rojo pequeño" },
  { name: "mca-navy", hex: "#083B66", origin: "Oficial", role: "Texto, H2/H3, fondos corporativos" },
  { name: "mca-navy-dark", hex: "#052642", origin: "Sugerido", role: "Hover navy · drawer móvil" },
  { name: "mca-white", hex: "#FFFFFF", origin: "Oficial", role: "Fondo principal" },
  { name: "mca-gold", hex: "#D4AF37", origin: "Sugerido", role: "Medallas · palmarés (restrictivo)" },
];

const slateTokens = [
  { name: "slate-50", hex: "#F8FAFC" },
  { name: "slate-100", hex: "#F1F5F9" },
  { name: "slate-200", hex: "#E2E8F0" },
  { name: "slate-300", hex: "#CBD5E1" },
  { name: "slate-400", hex: "#94A3B8" },
  { name: "slate-500", hex: "#64748B" },
  { name: "slate-700", hex: "#334155" },
  { name: "slate-900", hex: "#0F172A" },
];

const semanticTokens = [
  { name: "success", hex: "#10B981" },
  { name: "warning", hex: "#F59E0B" },
  { name: "error", hex: "#E31837" },
];

const wcagTable = [
  { combo: "red sobre white", ratio: "4.48:1", verdict: "⚠️", rule: "Solo títulos ≥18px o bold ≥14px" },
  { combo: "red-dark sobre white", ratio: "7.2:1", verdict: "✅", rule: "AAA · cualquier texto" },
  { combo: "navy sobre white", ratio: "9.48:1", verdict: "✅", rule: "AAA · cuerpo por defecto" },
  { combo: "white sobre navy-dark", ratio: "12.8:1", verdict: "✅", rule: "AAA · hero y secciones dark" },
  { combo: "red sobre navy", ratio: "2.9:1", verdict: "❌", rule: "Botón rojo necesita borde blanco" },
];
---

<BaseLayout title="Styleguide · MCA">
  <header class="bg-mca-navy-dark text-mca-white">
    <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-12 md:py-16">
      <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-2">
        Design System
      </p>
      <h1 class="text-5xl md:text-8xl leading-none font-display font-bold">
        Madrid Cheer Athletics
      </h1>
      <p class="mt-4 text-lg text-mca-slate-300 max-w-2xl">
        Hand-off v1.1 · Tokens, tipografía, componentes y reglas de uso de la web del club.
      </p>
      <p class="mt-6 italic text-mca-white/80">
        "No soñamos con ganar. Entrenamos para hacerlo."
      </p>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-16 md:py-24 space-y-24">
    <!-- 0. Brand assets -->
    <section aria-labelledby="brand-title">
      <h2 id="brand-title" class="text-4xl font-display font-bold mb-2">00 · Brand assets</h2>
      <p class="text-mca-slate-700 mb-8 max-w-3xl">
        Logos sobre los fondos correctos según el design system. Reglas de uso aplicadas.
      </p>

      <h3 class="text-2xl font-display font-bold mb-4">Logo circular</h3>
      <div class="grid md:grid-cols-2 gap-4 mb-12">
        <div class="bg-mca-white border border-mca-slate-200 rounded-sm p-12 flex flex-col items-center">
          <img src="/brand/logo-circular-rojo.png" alt="Logo MCA circular en rojo" class="w-40 h-40 object-contain" />
          <p class="text-xs text-mca-slate-500 uppercase tracking-widest mt-4">Sobre blanco · uso por defecto</p>
        </div>
        <div class="bg-mca-slate-50 border border-mca-slate-200 rounded-sm p-12 flex flex-col items-center">
          <img src="/brand/logo-circular-rojo.png" alt="Logo MCA circular en rojo" class="w-40 h-40 object-contain" />
          <p class="text-xs text-mca-slate-500 uppercase tracking-widest mt-4">Sobre slate-50</p>
        </div>
        <div class="bg-mca-navy-dark rounded-sm p-12 flex flex-col items-center">
          <img src="/brand/logo-circular-blanco.png" alt="Logo MCA circular en blanco" class="w-40 h-40 object-contain" />
          <p class="text-xs text-mca-slate-300 uppercase tracking-widest mt-4">Versión blanca · sobre navy-dark</p>
        </div>
        <div class="bg-mca-red rounded-sm p-12 flex flex-col items-center">
          <img src="/brand/logo-circular-blanco.png" alt="Logo MCA circular en blanco" class="w-40 h-40 object-contain" />
          <p class="text-xs text-mca-white/80 uppercase tracking-widest mt-4">Versión blanca · sobre red</p>
        </div>
      </div>

      <h3 class="text-2xl font-display font-bold mb-4">Wordmark MCA</h3>
      <div class="grid md:grid-cols-2 gap-4 mb-12">
        <div class="bg-mca-white border border-mca-slate-200 rounded-sm p-12 flex flex-col items-center">
          <img src="/brand/wordmark-mca-rojo.png" alt="Wordmark MCA en rojo" class="h-24 object-contain" />
          <p class="text-xs text-mca-slate-500 uppercase tracking-widest mt-4">Wordmark · uso navbar</p>
        </div>
        <div class="bg-mca-navy rounded-sm p-12 flex flex-col items-center">
          <img src="/brand/firma-email-mca-fondo-rojo.png" alt="Wordmark MCA blanco sobre fondo rojo" class="h-24 object-contain" />
          <p class="text-xs text-mca-white/80 uppercase tracking-widest mt-4">Banner horizontal · firma email</p>
        </div>
      </div>

      <h3 class="text-2xl font-display font-bold mb-4">Composiciones y motivos</h3>
      <div class="grid md:grid-cols-2 gap-4 mb-12">
        <div class="bg-mca-white border border-mca-slate-200 rounded-sm p-8 flex flex-col items-center">
          <img src="/brand/camiseta-reverso-eslogan.png" alt="Composición eslogan con estrellas dibujadas a mano" class="max-h-64 object-contain" />
          <p class="text-xs text-mca-slate-500 uppercase tracking-widest mt-4 text-center">
            Eslogan + estrellas · activo de marca a vectorizar
          </p>
        </div>
        <div class="bg-mca-slate-50 border border-mca-slate-200 rounded-sm p-8 flex flex-col items-center">
          <img src="/brand/ilustracion-pantera-pendiente.png" alt="Ilustración de pantera roja" class="max-h-64 object-contain" />
          <p class="text-xs uppercase tracking-widest mt-4 text-center">
            <span class="bg-mca-warning/20 text-mca-slate-900 px-2 py-0.5 rounded-sm">Pendiente confirmar con cliente</span>
          </p>
        </div>
      </div>

      <h3 class="text-2xl font-display font-bold mb-4">Watermark sutil</h3>
      <div class="relative bg-mca-navy-dark rounded-sm p-12 overflow-hidden mb-12 min-h-[280px]">
        <img src="/brand/logo-circular-blanco.png" alt="" class="absolute -right-16 -bottom-16 w-80 h-80 opacity-5 pointer-events-none" />
        <div class="relative">
          <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-2">Hero secundario</p>
          <h3 class="text-4xl text-mca-white font-display font-bold mb-4">Encuentra tu equipo</h3>
          <p class="text-mca-slate-300 max-w-xl">
            El logo circular como watermark al 5% de opacidad refuerza marca sin competir con el contenido. Patrón válido para hero secundarios y CTAs grandes.
          </p>
        </div>
      </div>

      <h3 class="text-2xl font-display font-bold mb-4">Área de seguridad</h3>
      <div class="bg-mca-slate-50 border border-mca-slate-200 rounded-sm p-12 flex flex-col items-center">
        <div class="relative inline-block">
          <span class="absolute -inset-8 border-2 border-dashed border-mca-red/40 rounded-full"></span>
          <img src="/brand/logo-circular-rojo.png" alt="Logo con área de seguridad" class="relative w-40 h-40 object-contain" />
        </div>
        <p class="text-xs text-mca-slate-500 uppercase tracking-widest mt-12 text-center max-w-md">
          Margen vacío equivalente a la altura de la "M" central. Nada más cerca que esta zona.
        </p>
      </div>
    </section>

    <!-- 1. Color -->
    <section aria-labelledby="color-title">
      <h2 id="color-title" class="text-4xl font-display font-bold mb-2">01 · Color</h2>
      <p class="text-mca-slate-700 mb-8 max-w-3xl">
        Paleta oficial extraída de los assets del club + sugeridos para estados e interfaz. Token CSS y rol de uso.
      </p>

      <h3 class="text-2xl font-display font-bold mb-4">Brand</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-12">
        {colorTokens.map((c) => (
          <div class="border border-mca-slate-200 rounded-sm overflow-hidden">
            <div class="h-24" style={`background-color: ${c.hex}`}></div>
            <div class="p-4">
              <div class="flex items-center justify-between">
                <code class="text-sm font-medium text-mca-navy">{c.name}</code>
                <span class={`text-xs uppercase tracking-wide px-2 py-0.5 rounded-sm ${c.origin === "Oficial" ? "bg-mca-navy text-mca-white" : "bg-mca-slate-100 text-mca-slate-700"}`}>
                  {c.origin}
                </span>
              </div>
              <p class="text-xs text-mca-slate-500 mt-1">{c.hex}</p>
              <p class="text-sm text-mca-slate-700 mt-2">{c.role}</p>
            </div>
          </div>
        ))}
      </div>

      <h3 class="text-2xl font-display font-bold mb-4">Neutros (slate)</h3>
      <div class="grid grid-cols-4 md:grid-cols-8 gap-2 mb-12">
        {slateTokens.map((c) => (
          <div class="text-center">
            <div class="h-16 rounded-sm border border-mca-slate-200" style={`background-color: ${c.hex}`}></div>
            <code class="block text-xs mt-2 text-mca-slate-700">{c.name}</code>
            <p class="text-xs text-mca-slate-400">{c.hex}</p>
          </div>
        ))}
      </div>

      <h3 class="text-2xl font-display font-bold mb-4">Semánticos</h3>
      <div class="grid grid-cols-3 gap-4 mb-12 max-w-2xl">
        {semanticTokens.map((c) => (
          <div class="text-center">
            <div class="h-16 rounded-sm border border-mca-slate-200" style={`background-color: ${c.hex}`}></div>
            <code class="block text-sm mt-2 text-mca-slate-700">{c.name}</code>
            <p class="text-xs text-mca-slate-400">{c.hex}</p>
          </div>
        ))}
      </div>

      <h3 class="text-2xl font-display font-bold mb-4">Reglas WCAG</h3>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-mca-slate-50 text-left">
              <th class="p-3 text-sm font-medium text-mca-navy border-b border-mca-slate-200">Combinación</th>
              <th class="p-3 text-sm font-medium text-mca-navy border-b border-mca-slate-200">Ratio</th>
              <th class="p-3 text-sm font-medium text-mca-navy border-b border-mca-slate-200">Veredicto</th>
              <th class="p-3 text-sm font-medium text-mca-navy border-b border-mca-slate-200">Regla</th>
            </tr>
          </thead>
          <tbody>
            {wcagTable.map((row) => (
              <tr class="border-b border-mca-slate-100">
                <td class="p-3 text-sm text-mca-slate-700"><code>{row.combo}</code></td>
                <td class="p-3 text-sm text-mca-slate-700">{row.ratio}</td>
                <td class="p-3 text-lg">{row.verdict}</td>
                <td class="p-3 text-sm text-mca-slate-700">{row.rule}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- 2. Tipografía -->
    <section aria-labelledby="type-title">
      <h2 id="type-title" class="text-4xl font-display font-bold mb-2">02 · Tipografía</h2>
      <p class="text-mca-slate-700 mb-8 max-w-3xl">
        Teko (display, H1-H3 uppercase) + Inter (body). Escala base 16px.
      </p>

      <div class="space-y-6">
        <div>
          <p class="text-xs uppercase tracking-widest text-mca-slate-500 mb-1">H1 desktop · Teko Bold · 96px</p>
          <h1 class="text-8xl leading-none">Madrid Cheer</h1>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-mca-slate-500 mb-1">H1 mobile · Teko Bold · 48px</p>
          <h1 class="text-5xl leading-none">Madrid Cheer</h1>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-mca-slate-500 mb-1">H2 · Teko Bold · 36px</p>
          <h2 class="text-4xl leading-none">Equipos competitivos</h2>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-mca-slate-500 mb-1">H3 · Teko/Inter · 24px</p>
          <h3 class="text-2xl leading-tight">Senior Elite</h3>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-mca-slate-500 mb-1">Body · Inter Regular · 16px</p>
          <p class="text-base max-w-2xl text-mca-navy leading-relaxed">
            Madrid Cheer Athletics nace de la pasión por el cheerleading y el compromiso con la excelencia deportiva. Somos un club en pleno crecimiento, formado por entrenadores profesionales y atletas dedicados.
          </p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-mca-slate-500 mb-1">Small · Inter · 14px</p>
          <p class="text-sm text-mca-slate-700">Metadatos, fechas, secundario.</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-mca-slate-500 mb-1">XS · Inter · 12px</p>
          <p class="text-xs text-mca-slate-500">Etiquetas pequeñas, footers legales, copyrights.</p>
        </div>
      </div>
    </section>

    <!-- 3. Botones -->
    <section aria-labelledby="buttons-title">
      <h2 id="buttons-title" class="text-4xl font-display font-bold mb-2">03 · Botones</h2>
      <p class="text-mca-slate-700 mb-8 max-w-3xl">
        Cuatro variantes. Todos rounded-sm (2px), uppercase, transición 150ms ease-out.
      </p>

      <div class="grid gap-8">
        <div>
          <p class="text-sm font-medium text-mca-slate-500 uppercase mb-3">Primary</p>
          <div class="flex flex-wrap gap-4 items-center">
            <Button variant="primary">Reserva tu prueba</Button>
            <Button variant="primary" disabled>Disabled</Button>
          </div>
        </div>

        <div>
          <p class="text-sm font-medium text-mca-slate-500 uppercase mb-3">Secondary</p>
          <div class="flex flex-wrap gap-4 items-center">
            <Button variant="secondary">Conócenos</Button>
            <Button variant="secondary" disabled>Disabled</Button>
          </div>
        </div>

        <div>
          <p class="text-sm font-medium text-mca-slate-500 uppercase mb-3">Ghost / Outline</p>
          <div class="flex flex-wrap gap-4 items-center">
            <Button variant="ghost">Ver equipos</Button>
            <Button variant="ghost" disabled>Disabled</Button>
          </div>
        </div>

        <div class="bg-mca-navy p-8 rounded-sm">
          <p class="text-sm font-medium text-mca-slate-300 uppercase mb-3">Primary sobre fondo navy (con borde blanco WCAG)</p>
          <div class="flex flex-wrap gap-4 items-center">
            <Button variant="primary-on-navy">Inscríbete ahora</Button>
            <Button variant="primary-on-navy" disabled>Disabled</Button>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. Inputs y formularios -->
    <section aria-labelledby="forms-title">
      <h2 id="forms-title" class="text-4xl font-display font-bold mb-2">04 · Inputs y formularios</h2>
      <p class="text-mca-slate-700 mb-8 max-w-3xl">
        Estados base, focus, error y disabled. Label sobre el input.
      </p>

      <form class="grid gap-6 max-w-xl">
        <Input id="nombre" label="Nombre" placeholder="Tu nombre" required />
        <Input id="email" label="Email" type="email" placeholder="tu@email.com" required />
        <Input id="error-demo" label="Email" type="email" value="malformado" error="Introduce un email válido" />
        <Input id="disabled-demo" label="Campo deshabilitado" disabled value="No editable" />

        <fieldset class="border-0 p-0">
          <legend class="text-sm font-medium text-mca-navy mb-2">Asunto</legend>
          <div class="space-y-2">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="asunto" class="w-4 h-4 accent-mca-red" checked />
              <span class="text-sm text-mca-navy">Información general</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="asunto" class="w-4 h-4 accent-mca-red" />
              <span class="text-sm text-mca-navy">Inscripciones</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="asunto" class="w-4 h-4 accent-mca-red" />
              <span class="text-sm text-mca-navy">Equipos competitivos</span>
            </label>
          </div>
        </fieldset>

        <label class="flex items-start gap-2 cursor-pointer">
          <input type="checkbox" class="w-4 h-4 mt-1 accent-mca-red" />
          <span class="text-sm text-mca-navy">Acepto la política de privacidad</span>
        </label>

        <Button variant="primary" type="submit">Enviar mensaje</Button>
      </form>
    </section>

    <!-- 5. Cards -->
    <section aria-labelledby="cards-title">
      <h2 id="cards-title" class="text-4xl font-display font-bold mb-2">05 · Cards</h2>
      <p class="text-mca-slate-700 mb-8 max-w-3xl">
        Estática y clickeable (hover con sombra navy + traslación).
      </p>

      <div class="grid md:grid-cols-3 gap-6">
        <Card>
          <h3 class="text-2xl mb-2">Cheerleading recreativo</h3>
          <p class="text-sm text-mca-slate-700">
            Fundamentos, acondicionamiento y coreografías básicas en ambiente relajado.
          </p>
        </Card>
        <Card href="#">
          <h3 class="text-2xl mb-2">Tumbling</h3>
          <p class="text-sm text-mca-slate-700">
            Acrobacia de suelo desde lo básico hasta pases avanzados. Grupos reducidos.
          </p>
          <p class="mt-4 text-sm font-medium text-mca-red uppercase">Saber más →</p>
        </Card>
        <Card href="#">
          <h3 class="text-2xl mb-2">Stunts y técnica</h3>
          <p class="text-sm text-mca-slate-700">
            Pirámides, elevaciones, bases y flyers. La seguridad como prioridad.
          </p>
          <p class="mt-4 text-sm font-medium text-mca-red uppercase">Saber más →</p>
        </Card>
      </div>
    </section>

    <!-- 6. Spacing y layout -->
    <section aria-labelledby="spacing-title">
      <h2 id="spacing-title" class="text-4xl font-display font-bold mb-2">06 · Spacing</h2>
      <p class="text-mca-slate-700 mb-8 max-w-3xl">
        Sistema base 4 de Tailwind. Visualización de los pasos clave.
      </p>

      <div class="space-y-3">
        {[2, 4, 6, 8, 12, 16, 24].map((s) => (
          <div class="flex items-center gap-4">
            <code class="text-sm text-mca-slate-700 w-20">gap-{s}</code>
            <span class="text-sm text-mca-slate-500 w-20">{s * 4}px</span>
            <div class="bg-mca-red h-4" style={`width: ${s * 4}px`}></div>
          </div>
        ))}
      </div>
    </section>

    <!-- 7. Pendientes -->
    <section class="bg-mca-slate-50 -mx-4 md:-mx-6 lg:-mx-8 px-4 md:px-6 lg:px-8 py-12 rounded-sm">
      <h2 class="text-4xl font-display font-bold mb-4">Pendientes para Gerardo</h2>
      <ul class="space-y-2 text-mca-slate-700 list-disc pl-5">
        <li>Validar uso de la pantera en web</li>
        <li>Confirmar el dorado <code class="text-sm">#D4AF37</code> como color de palmarés</li>
        <li>Equipos reales del club (el brief dice "estructura de ejemplo")</li>
        <li>Horarios concretos por equipo</li>
        <li>Modalidad final de la tienda (catálogo / e-commerce)</li>
        <li>URL del Google Forms de inscripción</li>
        <li>Datos fiscales para footer y aviso legal</li>
        <li>Política de privacidad / aviso legal / cookies (RGPD)</li>
        <li>Vectorización de logos y estrellas (SVG)</li>
        <li>Material visual definitivo (fotos reales)</li>
      </ul>
    </section>
  </main>

  <footer class="bg-mca-navy-dark text-mca-slate-300 py-8 mt-16">
    <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 text-sm">
      <p>Madrid Cheer Athletics · Styleguide v1.1 · {new Date().getFullYear()}</p>
    </div>
  </footer>
</BaseLayout>
