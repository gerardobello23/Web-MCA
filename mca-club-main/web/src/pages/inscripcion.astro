---
import SiteLayout from "../layouts/SiteLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";

// TODO: reemplazar por la URL real del Google Forms del cliente cuando Gerardo la facilite.
const googleFormsUrl = "https://forms.gle/WwwvoBnu9KF2tjL7A";

const steps = [
  {
    n: "01",
    title: "Solicita tu clase de prueba gratuita",
    description:
      "Rellena el formulario con tus datos básicos e indícanos tu experiencia previa, si la tienes.",
    detail:
      "Te confirmaremos fecha y hora por email o WhatsApp en un plazo de 24-48 horas.",
  },
  {
    n: "02",
    title: "Asiste a tu clase de prueba",
    description:
      "Ven con ropa deportiva cómoda y ganas de divertirte. Probarás una sesión real.",
    detail:
      "Conocerás al equipo de entrenadores y atletas que ya forman parte del club.",
  },
  {
    n: "03",
    title: "Inscripción oficial",
    description:
      "Si decides continuar, completas la documentación y eliges tu equipo y horario.",
    detail:
      "¡Bienvenido oficialmente a Madrid Cheer Athletics!",
  },
];

---

<SiteLayout
  title="Únete · Club de Cheerleading Madrid"
  description="Apúntate al club de cheerleading de Madrid. Primera clase gratuita sin compromiso."
>
  <!-- HERO -->
  <section class="relative bg-mca-navy-dark text-mca-white overflow-hidden">
    <img
      src="/brand/logo-circular-blanco.png"
      alt=""
      aria-hidden="true"
      class="absolute -right-24 -bottom-24 w-[28rem] h-[28rem] opacity-5 pointer-events-none"
    />
    <div class="relative max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-16 md:py-24">
      <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-4">
        Inscripción
      </p>
      <h1 class="text-5xl md:text-7xl leading-none font-display font-bold mb-6 max-w-3xl">
        Únete a Madrid Cheer Athletics
      </h1>
      <p class="text-lg md:text-xl text-mca-white/70 max-w-2xl">
        Estamos encantados de que quieras formar parte de nuestra comunidad. El
        proceso es sencillo y empezarás a entrenar antes de lo que imaginas.
      </p>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="py-16 md:py-24 bg-mca-white">
    <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
      <div class="max-w-3xl mb-12">
        <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-2">
          Cómo unirte
        </p>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-mca-navy">
          Tres pasos hasta tu primer entrenamiento
        </h2>
      </div>

      <ol class="grid md:grid-cols-3 gap-6">
        {
          steps.map((s) => (
            <li>
              <Card>
                <span class="block font-display text-6xl md:text-7xl text-mca-red leading-none mb-4">
                  {s.n}
                </span>
                <h3 class="text-2xl mb-2">{s.title}</h3>
                <p class="text-mca-slate-700 mb-4">{s.description}</p>
                <p class="text-sm text-mca-slate-500 italic">{s.detail}</p>
              </Card>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- FORMULARIO -->
  <section class="py-16 md:py-24 bg-mca-slate-50">
    <div class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8 text-center">
      <p class="text-sm uppercase tracking-widest text-mca-red font-medium mb-2">
        ¿Lista/o para dar el paso?
      </p>
      <h2 class="text-4xl md:text-5xl font-display font-bold text-mca-navy mb-4">
        Ya es el momento de hacerlo oficial
      </h2>
      <p class="text-mca-slate-700 text-lg mb-8">
        Ya probaste, ya conociste el equipo. Rellena el formulario de inscripción y nos pondremos en contacto contigo a la brevedad posible.
      </p>

      {
        googleFormsUrl === "#" ? (
          <div class="border border-dashed border-mca-slate-300 rounded-sm p-8 bg-mca-white text-left">
            <p class="text-xs uppercase tracking-widest text-mca-warning font-medium mb-2">
              Pendiente
            </p>
            <p class="text-mca-slate-700 text-sm mb-4">
              El club ya gestiona inscripciones a través de Google Forms. Cuando
              Gerardo facilite la URL pública del formulario, este botón apuntará
              directamente a él (o se incrustará dentro de la página si lo prefiere).
            </p>
            <Button variant="primary" disabled>
              Abrir formulario
            </Button>
          </div>
        ) : (
          <Button variant="primary" href={googleFormsUrl}>
            Abrir formulario de inscripción
          </Button>
        )
      }

      <p class="mt-6 text-sm text-mca-slate-500">
        ¿Prefieres escribirnos? <a
          href="https://wa.me/34643515820"
          class="text-mca-navy underline hover:text-mca-red transition-colors"
          >WhatsApp</a
        > · <a
          href="mailto:hola@madridcheer.com"
          class="text-mca-navy underline hover:text-mca-red transition-colors"
          >Email</a
        >
      </p>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-mca-navy text-mca-white">
    <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-16 md:py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        ¿Tienes más dudas?
      </h2>
      <p class="text-mca-white/70 text-lg max-w-xl mx-auto mb-8">
        Resolvemos cualquier pregunta antes de que te inscribas. Sin compromiso.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <Button variant="primary-on-navy" href="/contacto">
          Contáctanos
        </Button>
        <a
          href="https://wa.me/34643515820"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-sm border border-mca-white text-mca-white font-body font-medium uppercase tracking-wide text-sm transition-all duration-150 ease-out hover:bg-mca-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-mca-white focus-visible:ring-offset-2 focus-visible:ring-offset-mca-navy"
        >
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
