---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Madrid Cheer Athletics",
  description = "Club de cheerleading en Madrid. Entrenamientos, equipos competitivos y recreativos. No soñamos con ganar. Entrenamos para hacerlo.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="theme-color" content="#E31837" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Teko:wght@600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-167EYGMGDN"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-167EYGMGDN');
</script>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
