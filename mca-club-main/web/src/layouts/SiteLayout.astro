---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />

  <!-- MODAL PRUEBA GRATUITA -->
  <div id="modal-prueba" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4">
    <div class="relative bg-white rounded-lg max-w-lg w-full max-h-[90vh] overflow-y-auto p-6 md:p-8">
      <button id="modal-close" class="absolute top-4 right-4 text-gray-400 hover:text-gray-700">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <h2 id="modal-prueba-title" class="text-2xl font-bold text-mca-navy mb-1">Reserva tu clase gratuita</h2>
      <p id="modal-prueba-subtitle" class="text-sm text-gray-500 mb-6">Sin compromiso. Te confirmamos por WhatsApp.</p>

      <form id="prueba-form" class="space-y-4">
        <input type="hidden" name="subject" value="Nueva solicitud de prueba gratuita - Madrid Cheer Athletics">
        <input type="hidden" name="fuente" id="prueba-fuente" value="">

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Nombre completo <span class="text-mca-red">*</span></label>
          <input type="text" name="nombre" required class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Email <span class="text-mca-red">*</span></label>
          <input type="email" name="email" required class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Teléfono <span class="text-mca-red">*</span></label>
          <div class="flex gap-2">
            <select id="prefijo-tel" class="px-2 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red bg-white w-32 shrink-0">
              <option value="+34">🇪🇸 +34</option>
              <option value="+57">🇨🇴 +57</option>
              <option value="+52">🇲🇽 +52</option>
              <option value="+54">🇦🇷 +54</option>
              <option value="+58">🇻🇪 +58</option>
              <option value="+51">🇵🇪 +51</option>
              <option value="+56">🇨🇱 +56</option>
              <option value="+593">🇪🇨 +593</option>
              <option value="+1">🇺🇸 +1</option>
              <option value="+44">🇬🇧 +44</option>
              <option value="+33">🇫🇷 +33</option>
              <option value="+49">🇩🇪 +49</option>
              <option value="+39">🇮🇹 +39</option>
              <option value="+351">🇵🇹 +351</option>
              <option value="+31">🇳🇱 +31</option>
              <option value="+32">🇧🇪 +32</option>
              <option value="+41">🇨🇭 +41</option>
              <option value="+43">🇦🇹 +43</option>
              <option value="+48">🇵🇱 +48</option>
              <option value="+40">🇷🇴 +40</option>
              <option value="+30">🇬🇷 +30</option>
              <option value="+380">🇺🇦 +380</option>
              <option value="+7">🇷🇺 +7</option>
              <option value="+90">🇹🇷 +90</option>
              <option value="+86">🇨🇳 +86</option>
              <option value="+81">🇯🇵 +81</option>
              <option value="+82">🇰🇷 +82</option>
              <option value="+91">🇮🇳 +91</option>
              <option value="+55">🇧🇷 +55</option>
              <option value="+598">🇺🇾 +598</option>
              <option value="+595">🇵🇾 +595</option>
              <option value="+591">🇧🇴 +591</option>
              <option value="+503">🇸🇻 +503</option>
              <option value="+502">🇬🇹 +502</option>
              <option value="+504">🇭🇳 +504</option>
              <option value="+505">🇳🇮 +505</option>
              <option value="+506">🇨🇷 +506</option>
              <option value="+507">🇵🇦 +507</option>
              <option value="+1-809">🇩🇴 +1-809</option>
              <option value="+53">🇨🇺 +53</option>
              <option value="+212">🇲🇦 +212</option>
              <option value="+213">🇩🇿 +213</option>
              <option value="+20">🇪🇬 +20</option>
              <option value="+27">🇿🇦 +27</option>
              <option value="+234">🇳🇬 +234</option>
            </select>
            <input type="tel" name="telefono" required placeholder="600 000 000" class="flex-1 px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Fecha de nacimiento <span class="text-mca-red">*</span></label>
          <input type="date" name="fecha_nacimiento" required class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
        </div>

        <!-- SECCIÓN TUTOR — visible solo si el solicitante es menor de 18 -->
        <div id="tutor-section" class="hidden space-y-4 p-4 bg-blue-50 rounded border border-blue-200">
          <p class="text-sm font-medium text-mca-navy">Datos del padre/madre/tutor legal</p>
          <div>
            <label class="block text-sm font-medium text-mca-navy mb-1">Nombre completo del tutor <span class="text-mca-red">*</span></label>
            <input type="text" name="tutor_nombre" class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
          </div>
          <div>
            <label class="block text-sm font-medium text-mca-navy mb-1">Relación con el menor <span class="text-mca-red">*</span></label>
            <select name="tutor_relacion" class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red bg-white">
              <option value="">Selecciona</option>
              <option value="Padre">Padre</option>
              <option value="Madre">Madre</option>
              <option value="Tutor legal">Tutor legal</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-mca-navy mb-1">DNI/NIE del tutor <span class="text-mca-red">*</span></label>
            <input type="text" name="tutor_dni" placeholder="12345678A" class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-2">Experiencia <span class="text-mca-red">*</span></label>
          <div class="space-y-2">
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Sin experiencia" required class="mt-0.5 accent-mca-red"> Nunca practiqué este deporte
            </label>
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Practiqué alguna vez" class="mt-0.5 accent-mca-red"> Practiqué alguna vez
            </label>
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Gimnasia, danza u otro deporte similar" class="mt-0.5 accent-mca-red"> Practiqué gimnasia, danza u otro deporte similar
            </label>
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Nivel 1-3 competitivo" class="mt-0.5 accent-mca-red"> Hice nivel 1; 2 y/o 3 competitivo
            </label>
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Nivel 4-7 competitivo" class="mt-0.5 accent-mca-red"> Hice nivel 4; 5; 6 y/o 7 competitivo
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-2">Rol (puedes elegir varios)</label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="checkbox" name="rol_base" value="Base" class="accent-mca-red"> Soy base (principal, secundaria o spotter)
            </label>
            <label class="flex items-center gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="checkbox" name="rol_flyer" value="Flyer" class="accent-mca-red"> Soy flyer
            </label>
            <label class="flex items-center gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="checkbox" name="rol_gimnasia" value="Gimnasia" class="accent-mca-red"> Hago gimnasia (básica o avanzada)
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Condiciones médicas y/o lesiones <span class="text-mca-red">*</span></label>
          <input type="text" name="condiciones_medicas" placeholder="Escribe 'Ninguna' si no tienes" required class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Comentarios, preguntas o dudas</label>
          <textarea name="comentarios" rows="3" class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red"></textarea>
        </div>

        <!-- CONSENTIMIENTO ADULTO -->
        <label id="privacidad-adulto" class="flex items-start gap-2 cursor-pointer">
          <input type="checkbox" name="privacidad" required class="mt-0.5 accent-mca-red shrink-0">
          <span class="text-sm text-mca-navy">Acepto la <a href="/privacidad" data-privacy-modal class="underline hover:text-mca-red">política de privacidad</a></span>
        </label>

        <!-- CONSENTIMIENTO TUTOR — visible solo si el solicitante es menor de 18 -->
        <label id="privacidad-menor" class="hidden flex items-start gap-2 cursor-pointer">
          <input type="checkbox" name="privacidad_menor" class="mt-0.5 accent-mca-red shrink-0">
          <span class="text-sm text-mca-navy">Como padre/madre/tutor legal, consiento el tratamiento de los datos personales y de salud del menor por parte de Madrid Cheer Athletics, conforme a la <a href="/privacidad" data-privacy-modal class="underline hover:text-mca-red">política de privacidad</a>, incluyendo el uso de imágenes en actividades del club (art. 7 LOPDGDD y art. 9 RGPD).</span>
        </label>

        <div id="prueba-feedback" class="hidden rounded p-3 text-sm"></div>

        <button type="submit" class="w-full bg-mca-red text-white font-bold py-3 rounded hover:opacity-90 transition-opacity uppercase tracking-wide">
          Reservar clase gratuita
        </button>
      </form>
    </div>
  </div>

  <!-- INTENSIVO_VERANO_2026 START — eliminar este bloque completo en agosto 2026 -->
  <div id="modal-intensivo" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4">
    <div class="relative bg-white rounded-lg max-w-md w-full p-6 md:p-8">
      <button id="modal-intensivo-close" class="absolute top-4 right-4 text-gray-400 hover:text-gray-700">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <p class="text-xs uppercase tracking-widest text-mca-red font-semibold mb-2">Julio 2026</p>
      <h2 class="text-2xl font-bold text-mca-navy mb-3">Intensivo de Verano</h2>
      <p class="text-sm text-gray-600 mb-4">
        Cinco viernes de julio para perfeccionar tu técnica: subidas con giro, desmontes con giro, tictocs y switch ups, invertidas y figuras de flexibilidad.
      </p>
      <ul class="text-sm text-gray-700 space-y-1 mb-5">
        <li>📅 Viernes 3, 10, 17, 24 y 31 de julio</li>
        <li>🕖 19:00 – 22:00h</li>
        <li>💶 10€ por sesión, o 40€ el pack completo (la 5ª sesión, gratis)</li>
      </ul>
      <button data-prueba-modal data-source="intensivo_verano" class="w-full bg-mca-red text-white font-bold py-3 rounded hover:opacity-90 transition-opacity uppercase tracking-wide text-sm">
        Reservar mi plaza para las clases dirigidas
      </button>
    </div>
  </div>
  <!-- INTENSIVO_VERANO_2026 END -->

  <script>
import { supabase } from "../lib/supabase";
if (!(window as any).__mcaModalInit) {
  (window as any).__mcaModalInit = true;

    const modal = document.getElementById("modal-prueba");
    const modalClose = document.getElementById("modal-close");
    const pruebaForm = document.getElementById("prueba-form");
    const pruebaFeedback = document.getElementById("prueba-feedback");

    function openModal(e: Event) {
      e.preventDefault();
      const trigger = e.currentTarget as HTMLElement;
      const source = trigger?.getAttribute("data-source") || "";
      const fuenteInput = document.getElementById("prueba-fuente") as HTMLInputElement;
      if (fuenteInput) fuenteInput.value = source;

      const titleEl = document.getElementById("modal-prueba-title");
      const subtitleEl = document.getElementById("modal-prueba-subtitle");
      if (source === "intensivo_verano") {
        if (titleEl) titleEl.textContent = "Reserva tu plaza para el Intensivo de Verano";
        if (subtitleEl) subtitleEl.textContent = "Viernes de julio · 19h–22h. Sin compromiso.";
      } else {
        if (titleEl) titleEl.textContent = "Reserva tu clase gratuita";
        if (subtitleEl) subtitleEl.textContent = "Sin compromiso. Te confirmamos por WhatsApp.";
      }

      modal?.classList.remove("hidden");
      modal?.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modal?.classList.add("hidden");
      modal?.classList.remove("flex");
      document.body.style.overflow = "";
    }

    document.querySelectorAll("[data-prueba-modal]").forEach((btn) => {
      btn.addEventListener("click", openModal);
    });

    modalClose?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    pruebaForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(pruebaForm as HTMLFormElement);
      const prefijo = (document.getElementById("prefijo-tel") as HTMLSelectElement)?.value || "+34";
      const telefonoRaw = (formData.get("telefono") as string || "").trim();
      const telefono = `${prefijo} ${telefonoRaw}`;

      const roles = [];
      if (formData.get("rol_base")) roles.push("Base");
      if (formData.get("rol_flyer")) roles.push("Flyer");
      if (formData.get("rol_gimnasia")) roles.push("Gimnasia");

      const fechaNac = formData.get("fecha_nacimiento") as string;
      const dob = new Date(fechaNac);
      const today = new Date();
      let age = today.getFullYear() - dob.getFullYear();
      const m = today.getMonth() - dob.getMonth();
      if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) age--;
      const esMenor = age < 18;

      const payload = {
        nombre: formData.get("nombre"),
        email: formData.get("email"),
        telefono,
        fecha_nacimiento: fechaNac,
        experiencia: formData.get("experiencia"),
        rol: roles.join(", "),
        condiciones_medicas: formData.get("condiciones_medicas"),
        comentarios: formData.get("comentarios"),
        es_menor: esMenor,
        tutor_nombre: esMenor ? formData.get("tutor_nombre") : null,
        tutor_relacion: esMenor ? formData.get("tutor_relacion") : null,
        tutor_dni: esMenor ? formData.get("tutor_dni") : null,
        fuente: formData.get("fuente") || null,
        status: "interesado",
      };

      try {
        const { error } = await supabase.from("prospects").insert(payload);

        if (pruebaFeedback) {
          pruebaFeedback.classList.remove("hidden");
          if (!error) {
            pruebaFeedback.className = "rounded p-3 text-sm bg-green-50 text-green-700 border border-green-200";
            pruebaFeedback.textContent = "¡Solicitud enviada! Te contactaremos por WhatsApp lo antes posible.";
            (pruebaForm as HTMLFormElement).reset();

            fetch("https://app.madridcheer.com/api/prospects/notify", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                nombre: payload.nombre,
                email: payload.email,
                telefono: payload.telefono,
                rol: payload.rol,
                experiencia: payload.experiencia,
                fuente: payload.fuente,
              }),
            }).then(r => console.log('notify status:', r.status)).catch(err => console.error('notify error:', err));
          } else {
            pruebaFeedback.className = "rounded p-3 text-sm bg-red-50 text-red-700 border border-red-200";
            pruebaFeedback.textContent = "Error al enviar. Por favor inténtalo de nuevo.";
          }
        }
      } catch (err) {
        console.error('Error en formulario:', err);
        if (pruebaFeedback) {
          pruebaFeedback.classList.remove("hidden");
          pruebaFeedback.className = "rounded p-3 text-sm bg-red-50 text-red-700 border border-red-200";
          pruebaFeedback.textContent = "Error de conexión. Por favor inténtalo de nuevo.";
        }
      }
    });

    const fechaNacInput = pruebaForm?.querySelector('input[name="fecha_nacimiento"]') as HTMLInputElement;
    const tutorSection = document.getElementById('tutor-section');
    const privacidadAdulto = document.getElementById('privacidad-adulto');
    const privacidadMenor = document.getElementById('privacidad-menor');

    function checkAge() {
      if (!fechaNacInput?.value) return;
      const dob = new Date(fechaNacInput.value);
      const today = new Date();
      let age = today.getFullYear() - dob.getFullYear();
      const m = today.getMonth() - dob.getMonth();
      if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) age--;

      const esMenor = age < 18;
      tutorSection?.classList.toggle('hidden', !esMenor);
      privacidadAdulto?.classList.toggle('hidden', esMenor);
      privacidadMenor?.classList.toggle('hidden', !esMenor);

      const tutorInputs = tutorSection?.querySelectorAll('input, select');
      tutorInputs?.forEach(el => {
        if (esMenor) el.setAttribute('required', 'true');
        else el.removeAttribute('required');
      });

      const checkboxMenor = privacidadMenor?.querySelector('input[type="checkbox"]') as HTMLInputElement;
      if (checkboxMenor) checkboxMenor.required = esMenor;
      const checkboxAdulto = privacidadAdulto?.querySelector('input[type="checkbox"]') as HTMLInputElement;
      if (checkboxAdulto) checkboxAdulto.required = !esMenor;
    }

    fechaNacInput?.addEventListener('change', checkAge);
    fechaNacInput?.addEventListener('input', checkAge);
    fechaNacInput?.addEventListener('blur', checkAge);

    // INTENSIVO_VERANO_2026 START — eliminar este bloque completo en agosto 2026
    (function () {
      const cutoff = new Date('2026-08-01T00:00:00');
      if (new Date() >= cutoff) return;

      const modalIntensivo = document.getElementById('modal-intensivo');
      const closeIntensivo = document.getElementById('modal-intensivo-close');
      if (!modalIntensivo) return;

      function closeIntensivoModal() {
        modalIntensivo?.classList.add('hidden');
        modalIntensivo?.classList.remove('flex');
        document.body.style.overflow = '';
      }

      if (!sessionStorage.getItem('intensivoPopupShown')) {
        setTimeout(() => {
          modalIntensivo.classList.remove('hidden');
          modalIntensivo.classList.add('flex');
          document.body.style.overflow = 'hidden';
        }, 1200);
        sessionStorage.setItem('intensivoPopupShown', '1');
      }

      closeIntensivo?.addEventListener('click', closeIntensivoModal);
      modalIntensivo.addEventListener('click', (e) => {
        if (e.target === modalIntensivo) closeIntensivoModal();
      });
      modalIntensivo.querySelector('[data-prueba-modal]')?.addEventListener('click', closeIntensivoModal);
    })();
    // INTENSIVO_VERANO_2026 END
}
  </script>
</BaseLayout>
