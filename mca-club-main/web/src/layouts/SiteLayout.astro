---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />

  <!-- MODAL PRUEBA GRATUITA -->
  <div id="modal-prueba" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4">
    <div class="relative bg-white rounded-lg max-w-lg w-full max-h-[90vh] overflow-y-auto p-6 md:p-8">
      <button id="modal-close" class="absolute top-4 right-4 text-gray-400 hover:text-gray-700">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <h2 class="text-2xl font-bold text-mca-navy mb-1">Reserva tu clase gratuita</h2>
      <p class="text-sm text-gray-500 mb-6">Sin compromiso. Te confirmamos por WhatsApp.</p>

      <form id="prueba-form" class="space-y-4">
        <input type="hidden" name="access_key" value="54764054-bd5a-417d-b138-c333a0f96bc1">
        <input type="hidden" name="subject" value="Nueva solicitud de prueba gratuita - Madrid Cheer Athletics">

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Nombre completo <span class="text-mca-red">*</span></label>
          <input type="text" name="nombre" required class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Email <span class="text-mca-red">*</span></label>
          <input type="email" name="email" required class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Teléfono <span class="text-mca-red">*</span></label>
          <input type="tel" name="telefono" required class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Fecha de nacimiento <span class="text-mca-red">*</span></label>
          <input type="date" name="fecha_nacimiento" required class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-2">Experiencia <span class="text-mca-red">*</span></label>
          <div class="space-y-2">
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Sin experiencia" required class="mt-0.5 accent-mca-red"> Nunca practiqué este deporte
            </label>
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Practiqué alguna vez" class="mt-0.5 accent-mca-red"> Practiqué alguna vez
            </label>
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Gimnasia, danza u otro deporte similar" class="mt-0.5 accent-mca-red"> Practiqué gimnasia, danza u otro deporte similar
            </label>
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Nivel 1-3 competitivo" class="mt-0.5 accent-mca-red"> Hice nivel 1; 2 y/o 3 competitivo
            </label>
            <label class="flex items-start gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="radio" name="experiencia" value="Nivel 4-7 competitivo" class="mt-0.5 accent-mca-red"> Hice nivel 4; 5; 6 y/o 7 competitivo
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-2">Rol (puedes elegir varios)</label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="checkbox" name="rol_base" value="Base" class="accent-mca-red"> Soy base (principal, secundaria o spotter)
            </label>
            <label class="flex items-center gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="checkbox" name="rol_flyer" value="Flyer" class="accent-mca-red"> Soy flyer
            </label>
            <label class="flex items-center gap-2 text-sm text-mca-navy cursor-pointer">
              <input type="checkbox" name="rol_gimnasia" value="Gimnasia" class="accent-mca-red"> Hago gimnasia (básica o avanzada)
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Condiciones médicas y/o lesiones <span class="text-mca-red">*</span></label>
          <input type="text" name="condiciones_medicas" placeholder="Escribe 'Ninguna' si no tienes" required class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red">
        </div>

        <div>
          <label class="block text-sm font-medium text-mca-navy mb-1">Comentarios, preguntas o dudas</label>
          <textarea name="comentarios" rows="3" class="w-full px-3 py-2 rounded border border-gray-300 text-mca-navy text-sm focus:outline-none focus:border-mca-red"></textarea>
        </div>

        <label class="flex items-start gap-2 cursor-pointer">
          <input type="checkbox" name="privacidad" required class="mt-0.5 accent-mca-red shrink-0">
          <span class="text-sm text-mca-navy">Acepto la <a href="/privacidad" class="underline hover:text-mca-red">política de privacidad</a> <span class="text-mca-red">*</span></span>
        </label>

        <div id="prueba-feedback" class="hidden rounded p-3 text-sm"></div>

        <button type="submit" class="w-full bg-mca-red text-white font-bold py-3 rounded hover:opacity-90 transition-opacity uppercase tracking-wide">
          Reservar clase gratuita
        </button>
      </form>
    </div>
  </div>

  <script>

    const modal = document.getElementById("modal-prueba");
    const modalClose = document.getElementById("modal-close");
    const pruebaForm = document.getElementById("prueba-form");
    const pruebaFeedback = document.getElementById("prueba-feedback");

    function openModal(e: Event) {
      e.preventDefault();
      modal?.classList.remove("hidden");
      modal?.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modal?.classList.add("hidden");
      modal?.classList.remove("flex");
      document.body.style.overflow = "";
    }

    document.querySelectorAll("[data-prueba-modal]").forEach((btn) => {
      btn.addEventListener("click", openModal);
    });

    modalClose?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    pruebaForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(pruebaForm as HTMLFormElement);
      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: formData,
        });
        if (pruebaFeedback) {
          pruebaFeedback.classList.remove("hidden");
          if (response.ok) {
            pruebaFeedback.className = "rounded p-3 text-sm bg-green-50 text-green-700 border border-green-200";
            pruebaFeedback.textContent = "¡Solicitud enviada! Te confirmaremos por WhatsApp en 24-48 horas.";
            (pruebaForm as HTMLFormElement).reset();
          } else {
            pruebaFeedback.className = "rounded p-3 text-sm bg-red-50 text-red-700 border border-red-200";
            pruebaFeedback.textContent = "Error al enviar. Por favor inténtalo de nuevo.";
          }
        }
      } catch {
        if (pruebaFeedback) {
          pruebaFeedback.classList.remove("hidden");
          pruebaFeedback.className = "rounded p-3 text-sm bg-red-50 text-red-700 border border-red-200";
          pruebaFeedback.textContent = "Error de conexión. Por favor inténtalo de nuevo.";
        }
      }
    });
  </script>
</BaseLayout>
