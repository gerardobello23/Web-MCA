---
import Button from "./Button.astro";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/¿quienes-somos?", label: "Quiénes somos" },
  { href: "/entrenamientos", label: "Entrenamientos" },
  { href: "/equipos", label: "Equipos" },
  { href: "/inscripcion", label: "Inscripción" },
  { href: "/tienda", label: "Tienda" },
  { href: "/contacto", label: "Contacto" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header class="sticky top-0 z-40 bg-mca-white border-b border-mca-slate-100">
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href="/" class="flex items-center" aria-label="Madrid Cheer Athletics · Inicio">
        <img
          src="/brand/wordmark-mca-rojo.png"
          alt="Madrid Cheer Athletics"
          class="h-14 md:h-16 w-auto"
        />
      </a>

      <nav class="hidden lg:flex items-center gap-8" aria-label="Navegación principal">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "text-sm font-medium uppercase tracking-wide transition-colors duration-150",
                isActive(item.href)
                  ? "text-mca-red"
                  : "text-mca-navy hover:text-mca-red",
              ]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden lg:block">
        <Button variant="primary" href="/inscripcion">Únete al equipo</Button>
      </div>

      <button
        type="button"
        class="lg:hidden inline-flex items-center justify-center w-10 h-10 text-mca-navy focus:outline-none focus-visible:ring-2 focus-visible:ring-mca-navy rounded-sm"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        data-drawer-toggle
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<div
  id="mobile-drawer-overlay"
  class="lg:hidden fixed inset-0 z-40 bg-mca-slate-900/60 opacity-0 pointer-events-none transition-opacity duration-200 ease-out"
  data-drawer-overlay
  aria-hidden="true"
></div>

<aside
  id="mobile-drawer"
  class="lg:hidden fixed top-0 right-0 z-50 h-full w-[85%] max-w-sm bg-mca-navy-dark text-mca-white translate-x-full transition-transform duration-200 ease-out flex flex-col"
  aria-hidden="true"
  aria-label="Menú móvil"
  data-drawer-panel
>
  <div class="flex items-center justify-between px-4 py-4 border-b border-mca-white/10">
    <img src="/brand/logo-circular-blanco.png" alt="" class="h-10 w-10" />
    <button
      type="button"
      class="inline-flex items-center justify-center w-10 h-10 text-mca-white focus:outline-none focus-visible:ring-2 focus-visible:ring-mca-white rounded-sm"
      aria-label="Cerrar menú"
      data-drawer-close
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto px-4 py-6" aria-label="Navegación móvil">
    <ul class="space-y-2">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "block py-3 px-3 text-2xl font-display uppercase tracking-wide rounded-sm transition-colors duration-150",
                isActive(item.href)
                  ? "bg-mca-red text-mca-white"
                  : "text-mca-white hover:bg-mca-white/5",
              ]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="px-4 py-4 border-t border-mca-white/10">
    <Button variant="primary-on-navy" href="/inscripcion" class="w-full">
      Únete al equipo
    </Button>
  </div>
</aside>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-drawer-toggle]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-drawer-close]");
  const overlay = document.querySelector<HTMLDivElement>("[data-drawer-overlay]");
  const panel = document.querySelector<HTMLDivElement>("[data-drawer-panel]");

  if (toggle && closeBtn && overlay && panel) {
    const open = () => {
      panel.classList.remove("translate-x-full");
      panel.setAttribute("aria-hidden", "false");
      overlay.classList.remove("opacity-0", "pointer-events-none");
      toggle.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      panel.classList.add("translate-x-full");
      panel.setAttribute("aria-hidden", "true");
      overlay.classList.add("opacity-0", "pointer-events-none");
      toggle.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    };

    toggle.addEventListener("click", open);
    closeBtn.addEventListener("click", close);
    overlay.addEventListener("click", close);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && panel.getAttribute("aria-hidden") === "false") {
        close();
      }
    });
  }
</script>
