---
const navColumns = [
  {
    title: "Club",
    links: [
      { href: "/quienes-somos", label: "Quiénes somos" },
      { href: "/entrenamientos", label: "Entrenamientos" },
      { href: "/equipos", label: "Equipos" },
    ],
  },
  {
    title: "Únete",
    links: [
      { href: "/inscripcion", label: "Inscripción" },
      { href: "/tienda", label: "Tienda" },
      { href: "/contacto", label: "Contacto" },
    ],
  },
];

const social = [
  {
    href: "https://www.instagram.com/mca_cheerleadingclub/",
    label: "Instagram",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    href: "https://www.tiktok.com/@mca_cheerleadingclub",
    label: "TikTok",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.5a8.15 8.15 0 0 0 4.78 1.52V6.59a4.83 4.83 0 0 1-1.85.1z"/></svg>`,
  },
  {
    href: "https://wa.me/34643515820",
    label: "WhatsApp",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
  },
];

const year = new Date().getFullYear();
---

<footer class="relative bg-mca-navy-dark text-mca-white/70 overflow-hidden">
  <img
    src="/brand/logo-circular-blanco.png"
    alt=""
    aria-hidden="true"
    class="absolute -right-24 -bottom-24 w-96 h-96 opacity-5 pointer-events-none"
  />

  <div class="relative max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-16">
    <div class="grid gap-12 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <img src="/brand/logo-circular-blanco.png" alt="Madrid Cheer Athletics" class="w-20 h-20 mb-4" />
        <p class="text-mca-white text-2xl font-display uppercase leading-tight mb-2">
          Madrid<br />Cheer<br />Athletics
        </p>
        <p class="italic text-sm text-mca-white/70 max-w-xs">
          "No soñamos con ganar. Entrenamos para hacerlo."
        </p>
      </div>

      <div>
        <h3 class="text-sm uppercase tracking-widest text-mca-red font-medium mb-4">Contacto</h3>
        <address class="not-italic text-sm space-y-2">
          <p>
            Calle de Vital Aza, 56<br />
            Ciudad Lineal<br />
            28017 Madrid
          </p>
          <p>
            <a href="mailto:hola@madridcheer.com" class="hover:text-mca-white transition-colors">hola@madridcheer.com</a>
          </p>
          <p>
            <a href="https://wa.me/34643515820" class="hover:text-mca-white transition-colors">+34 643 51 58 20</a>
          </p>
        </address>
      </div>

      {
        navColumns.map((col) => (
          <div>
            <h3 class="text-sm uppercase tracking-widest text-mca-red font-medium mb-4">{col.title}</h3>
            <ul class="space-y-2 text-sm">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} class="hover:text-mca-white transition-colors">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12 pt-8 border-t border-mca-white/10 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <ul class="flex items-center gap-4">
        {
          social.map((s) => (
            <li>
              <a
                href={s.href}
                class="inline-flex items-center justify-center w-10 h-10 rounded-sm text-mca-white/60 hover:text-mca-white hover:bg-mca-white/5 transition-colors"
                aria-label={s.label}
                target="_blank"
                rel="noopener noreferrer"
                set:html={s.icon}
              />
            </li>
          ))
        }
      </ul>

      <div class="text-xs text-mca-white/50 flex flex-wrap gap-x-6 gap-y-2">
        <span>© {year} Madrid Cheer Athletics</span>
        <a href="/aviso-legal" class="hover:text-mca-white transition-colors">Aviso legal</a>
        <a href="/privacidad" class="hover:text-mca-white transition-colors">Privacidad</a>
        <a href="/cookies" class="hover:text-mca-white transition-colors">Cookies</a>
      </div>
    </div>
  </div>
</footer>
